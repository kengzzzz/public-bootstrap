LLAMA_ENV_FILE=.env
HF_TOKEN=
BENCHMARK_BASELINE_IMAGE=ghcr.io/ggml-org/llama.cpp:full-cuda13
BENCHMARK_CANDIDATE_IMAGE=llama-server
BENCHMARK_COMPOSE_FILE=docker-compose.yml
BENCHMARK_COMPOSE_SERVICE=llama-server
LLAMA_ARG_HF_REPO=unsloth/Qwen3.6-35B-A3B-GGUF:UD-Q6_K_XL
LLAMA_ARG_N_GPU_LAYERS=999
LLAMA_ARG_N_PARALLEL=1
LLAMA_ARG_FLASH_ATTN=on
LLAMA_ARG_CTX_SIZE=131072
LLAMA_ARG_CACHE_TYPE_K=q8_0
LLAMA_ARG_CACHE_TYPE_V=q8_0
LLAMA_ARG_N_CPU_MOE=28
LLAMA_ARG_MMAP=off
LLAMA_ARG_JINJA=on
LLAMA_ARG_REASONING=on
LLAMA_ARG_THINK=deepseek
LLAMA_ARG_TEMP=0.6
LLAMA_ARG_TOP_P=0.95
LLAMA_ARG_TOP_K=20
LLAMA_ARG_MIN_P=0.0
LLAMA_ARG_PRESENCE_PENALTY=0.0
LLAMA_ARG_REPEAT_PENALTY=1.0
LLAMA_ARG_HOST=0.0.0.0
LLAMA_ARG_PORT=8080
TS_AUTHKEY=
TS_EXTRA_ARGS=
